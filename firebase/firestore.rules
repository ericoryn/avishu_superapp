rules_version = '2';

// Avishu SuperApp firestore rules
// Деплой: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function getUserRole() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data.role : '';
    }

    function isStaff() {
      let role = getUserRole();
      return role == 'franchisee'
        || role == 'production'
        || role == 'factory';
    }

    function validStatusTransition(oldS, newS) {
      return (oldS == 'ОФОРМЛЕН' && newS == 'НА ПОШИВЕ')
        || (oldS == 'НА ПОШИВЕ' && newS == 'ГОТОВО');
    }

    // User profiles
    match /users/{userId} {
      allow read: if request.auth != null;

      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['name', 'role', 'email'])
        && request.resource.data.role in ['client', 'franchisee', 'production', 'factory'];

      allow delete: if false;
    }

    // Orders
    match /orders/{orderId} {
      // Any authenticated user can read orders
      // (staff sees all, client filtering is done client-side)
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.clientId == request.auth.uid
        && request.resource.data.status == 'ОФОРМЛЕН';

      allow update: if request.auth != null && isStaff()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && validStatusTransition(resource.data.status, request.resource.data.status);

      allow delete: if false;
    }
  }
}
